# --- CSOSINT: пример конфигурации (скопируй в .env) ---
# Модель развёртывания — self-host: свои ключи держишь у себя (ТЗ §9, §11.3).

# --- Инфраструктура ---
POSTGRES_USER=csosint
POSTGRES_PASSWORD=csosint
POSTGRES_DB=csosint
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Полный DSN (переопределяет части выше, если задан). asyncpg-драйвер.
DATABASE_URL=postgresql+asyncpg://csosint:csosint@postgres:5432/csosint

REDIS_URL=redis://redis:6379/0

# --- Core-источники (ТЗ §4) ---
# NVD: без ключа 5 req/30s, с ключом 50/30s. Ключ бесплатный, по email — получи.
NVD_API_KEY=
# InternetDB — без ключа, ничего указывать не нужно.

# --- Optional enrichment (свой ключ → более сильные результаты, ТЗ §4.5) ---
# Пусто → источник тихо пропускается (graceful degradation).
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=

# --- Поведение синка NVD (design-nvd-sync) ---
NVD_SYNC_MIN_DELAY_SECONDS=6
NVD_SYNC_PAGE_SIZE=2000
